{
  "name": "dota-record",
  "version": "1.0.0",
  "private": true,
  "workspaces": ["backend", "frontend"],
  "scripts": {
    "dev": "concurrently \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "build": "npm run build -w frontend",
    "start": "npm run start -w backend",
    "export-seed": "node scripts/export-seed.mjs",
    "pages:dev": "wrangler pages dev frontend/dist --d1 DB=dota-record",
    "pages:deploy": "node scripts/deploy.mjs",
    "backup": "node scripts/backup.mjs"
  },
  "dependencies": {
    "hono": "^4.6.14"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250109.0",
    "concurrently": "^9.1.2",
    "wrangler": "^3.99.0"
  }
}
